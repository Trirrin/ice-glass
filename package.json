{
  "name": "ice-glass",
  "version": "0.1.0",
  "description": "A refractive ice-glass UI effect built from an SVG displacement filter, a backdrop blur and a brightened edge mask — with vanilla, React and Vue bindings.",
  "author": "Trirrin <xrain6819@hotmail.com> (https://github.com/Trirrin)",
  "license": "MIT",
  "keywords": [
    "ui",
    "glass",
    "glassmorphism",
    "ice-glass",
    "refraction",
    "backdrop-filter",
    "svg-filter",
    "displacement",
    "react",
    "vue",
    "component"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Trirrin/ice-glass.git"
  },
  "bugs": {
    "url": "https://github.com/Trirrin/ice-glass/issues"
  },
  "homepage": "https://trirrin.github.io/ice-glass/",
  "type": "module",
  "sideEffects": [
    "./dist/auto.js",
    "./dist/auto.cjs",
    "**/*.css"
  ],
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "import": "./dist/auto.js",
      "require": "./dist/auto.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup && cp src/style.css dist/style.css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "vue": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vue": "^3.5.13"
  }
}
